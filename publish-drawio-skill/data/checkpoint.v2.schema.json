{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents365.local/drawio-skill/schemas/checkpoint.v2.schema.json",
  "title": "Executable diagram checkpoint v2",
  "type": "object",
  "required": ["schema_version", "checkpoint_id", "run_id", "checkpoint_type", "created_at", "transaction_id", "state_sha256", "source_bundle_sha256", "allowed_decisions", "context", "previous_snapshot_sha256"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 2},
    "checkpoint_id": {"$ref": "#/$defs/nonEmpty"},
    "run_id": {"$ref": "#/$defs/nonEmpty"},
    "checkpoint_type": {"enum": ["semantic_approval", "feedback", "diagnostic", "plateau", "publication_conflict", "final_acceptance", "role_contract", "manual_handoff"]},
    "created_at": {"type": "string", "format": "date-time"},
    "transaction_id": {"$ref": "#/$defs/nonEmpty"},
    "state_sha256": {"$ref": "#/$defs/sha"},
    "source_bundle_sha256": {"$ref": "#/$defs/sha"},
    "baseline_semantic_digest": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "semantic_plan_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "semantic_delta_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "accepted_artifact": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/file"}]},
    "allowed_decisions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["continue", "approve", "approve_with_findings", "reject", "pause", "stop", "manual_handoff", "retry", "keep_target", "publish_candidate"]}},
    "context": {"type": "object"},
    "previous_snapshot_sha256": {"$ref": "#/$defs/nullableSha"}
  },
  "$defs": {
    "nonEmpty": {"type": "string", "minLength": 1},
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "nullableSha": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "relativePath": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "file": {
      "type": "object",
      "required": ["path", "sha256", "byte_length"],
      "additionalProperties": false,
      "properties": {
        "path": {"$ref": "#/$defs/relativePath"},
        "sha256": {"$ref": "#/$defs/sha"},
        "byte_length": {"type": "integer", "minimum": 0}
      }
    }
  }
}
