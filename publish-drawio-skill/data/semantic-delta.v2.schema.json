{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents365.local/drawio-skill/schemas/semantic-delta.v2.schema.json",
  "title": "Typed page-scoped semantic delta v2",
  "type": "object",
  "required": ["schema_version", "baseline_semantic_digest", "source_bundle_sha256", "operations"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 2},
    "baseline_semantic_digest": {"$ref": "#/$defs/sha"},
    "source_bundle_sha256": {"$ref": "#/$defs/sha"},
    "operations": {"type": "array", "items": {"$ref": "#/$defs/operation"}}
  },
  "$defs": {
    "nonEmpty": {"type": "string", "minLength": 1},
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "jsonValue": {"type": ["object", "array", "string", "number", "boolean", "null"]},
    "identity": {
      "type": "object",
      "required": ["page_id", "cell_id"],
      "additionalProperties": false,
      "properties": {"page_id": {"$ref": "#/$defs/nonEmpty"}, "cell_id": {"$ref": "#/$defs/nonEmpty"}}
    },
    "change": {
      "type": "object",
      "required": ["field", "before", "after"],
      "additionalProperties": false,
      "properties": {
        "field": {"enum": ["label", "semantic_type", "style_hint", "parent", "source", "target", "relationship", "element"]},
        "before": {"$ref": "#/$defs/jsonValue"},
        "after": {"$ref": "#/$defs/jsonValue"}
      }
    },
    "operation": {
      "type": "object",
      "required": ["operation_id", "operation_type", "element_kind", "target", "changes"],
      "additionalProperties": false,
      "properties": {
        "operation_id": {"type": "string", "pattern": "^op-[a-f0-9]{20}$"},
        "operation_type": {"enum": ["add", "remove", "update", "relationship", "parent"]},
        "element_kind": {"enum": ["node", "edge", "group"]},
        "target": {"$ref": "#/$defs/identity"},
        "changes": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/change"}}
      }
    }
  }
}
