{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents365.local/drawio-skill/schemas/workflow.v2.schema.json",
  "title": "Diagram lifecycle workflow v2",
  "type": "object",
  "required": ["schema_version", "run_id", "mode", "workspace", "run_dir", "target_path", "target_initial_sha256", "created_at", "transaction_id", "state_snapshot", "source_bundle", "implementation_snapshot", "previous_snapshot_sha256", "quality_profile_version"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 2},
    "run_id": {"$ref": "#/$defs/nonEmpty"},
    "mode": {"enum": ["create", "improve", "review"]},
    "workspace": {"$ref": "#/$defs/absolutePath"},
    "run_dir": {"$ref": "#/$defs/relativePath"},
    "target_path": {"$ref": "#/$defs/relativePath"},
    "target_initial_sha256": {"$ref": "#/$defs/nullableSha"},
    "created_at": {"type": "string", "format": "date-time"},
    "transaction_id": {"$ref": "#/$defs/nonEmpty"},
    "state_snapshot": {"$ref": "#/$defs/snapshot"},
    "source_bundle": {"$ref": "#/$defs/snapshot"},
    "implementation_snapshot": {"$ref": "#/$defs/snapshot"},
    "latest_checkpoint": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/snapshot"}]},
    "publication_transaction": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/snapshot"}]},
    "previous_snapshot_sha256": {"$ref": "#/$defs/nullableSha"},
    "quality_profile_version": {"enum": [1, 2]}
  },
  "allOf": [
    {"if": {"properties": {"mode": {"const": "create"}}, "required": ["mode"]}, "then": {"properties": {"target_initial_sha256": {"type": "null"}}}},
    {"if": {"properties": {"mode": {"enum": ["improve", "review"]}}, "required": ["mode"]}, "then": {"properties": {"target_initial_sha256": {"$ref": "#/$defs/sha"}}}}
  ],
  "$defs": {
    "nonEmpty": {"type": "string", "minLength": 1},
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "nullableSha": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "absolutePath": {"type": "string", "pattern": "^/"},
    "relativePath": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "snapshot": {
      "type": "object",
      "required": ["schema_version", "schema_kind", "path", "sha256", "canonical_sha256", "byte_length", "previous_snapshot_sha256", "transaction_id"],
      "additionalProperties": false,
      "properties": {
        "schema_version": {"const": 2},
        "schema_kind": {"$ref": "#/$defs/nonEmpty"},
        "path": {"$ref": "#/$defs/relativePath"},
        "sha256": {"$ref": "#/$defs/sha"},
        "canonical_sha256": {"$ref": "#/$defs/sha"},
        "byte_length": {"type": "integer", "minimum": 0},
        "previous_snapshot_sha256": {"$ref": "#/$defs/nullableSha"},
        "transaction_id": {"$ref": "#/$defs/nonEmpty"}
      }
    }
  }
}
