{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents365.local/drawio-skill/schemas/validation-receipt.v2.schema.json",
  "title": "Trusted validator receipt v2",
  "type": "object",
  "required": ["schema_version", "receipt_id", "run_id", "attempt_id", "attempt_dir", "started_at", "finished_at", "strict", "artifact", "command", "exit_code", "validator", "bindings", "outputs", "result"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 2},
    "receipt_id": {"$ref": "#/$defs/nonEmpty"},
    "run_id": {"$ref": "#/$defs/nonEmpty"},
    "attempt_id": {"$ref": "#/$defs/nonEmpty"},
    "attempt_dir": {"$ref": "#/$defs/relativePath"},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "strict": {"const": true},
    "artifact": {"$ref": "#/$defs/file"},
    "command": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "exit_code": {"type": "integer", "minimum": 0},
    "validator": {
      "type": "object",
      "required": ["name", "version", "path", "file_sha256"],
      "additionalProperties": false,
      "properties": {
        "name": {"$ref": "#/$defs/nonEmpty"},
        "version": {"$ref": "#/$defs/nonEmpty"},
        "path": {"$ref": "#/$defs/relativePath"},
        "file_sha256": {"$ref": "#/$defs/sha"}
      }
    },
    "bindings": {
      "type": "object",
      "required": ["implementation_snapshot_sha256", "source_bundle_sha256", "candidate_sha256"],
      "additionalProperties": false,
      "properties": {
        "implementation_snapshot_sha256": {"$ref": "#/$defs/sha"},
        "source_bundle_sha256": {"$ref": "#/$defs/sha"},
        "candidate_sha256": {"$ref": "#/$defs/sha"}
      }
    },
    "outputs": {
      "type": "object",
      "required": ["report", "stdout", "stderr"],
      "additionalProperties": false,
      "properties": {
        "report": {"$ref": "#/$defs/file"},
        "stdout": {"$ref": "#/$defs/file"},
        "stderr": {"$ref": "#/$defs/file"}
      }
    },
    "result": {"enum": ["passed", "failed"]}
  },
  "allOf": [
    {"if": {"properties": {"result": {"const": "passed"}}, "required": ["result"]}, "then": {"properties": {"exit_code": {"const": 0}}}},
    {"if": {"properties": {"result": {"const": "failed"}}, "required": ["result"]}, "then": {"properties": {"exit_code": {"minimum": 1}}}}
  ],
  "$defs": {
    "nonEmpty": {"type": "string", "minLength": 1},
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "relativePath": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "file": {
      "type": "object",
      "required": ["path", "sha256", "byte_length"],
      "additionalProperties": false,
      "properties": {
        "path": {"$ref": "#/$defs/relativePath"},
        "sha256": {"$ref": "#/$defs/sha"},
        "byte_length": {"type": "integer", "minimum": 0}
      }
    }
  }
}
