{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents365.local/drawio-skill/schemas/reviewer-verdict.v2.schema.json",
  "title": "Host-bound Reviewer verdict v2",
  "type": "object",
  "required": ["schema_version", "verdict_id", "analysis_id", "run_id", "analysis_sha256", "role_input_sha256", "role_output_sha256", "bindings", "runtime_proof", "verdict", "reviewed_at", "findings"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 2},
    "verdict_id": {"$ref": "#/$defs/nonEmpty"},
    "analysis_id": {"$ref": "#/$defs/nonEmpty"},
    "run_id": {"$ref": "#/$defs/nonEmpty"},
    "analysis_sha256": {"$ref": "#/$defs/sha"},
    "role_input_sha256": {"$ref": "#/$defs/sha"},
    "role_output_sha256": {"$ref": "#/$defs/sha"},
    "bindings": {
      "type": "object",
      "required": ["candidate_sha256", "report_sha256", "receipt_sha256", "source_bundle_sha256", "semantic_plan_sha256", "semantic_delta_sha256"],
      "additionalProperties": false,
      "properties": {
        "candidate_sha256": {"$ref": "#/$defs/sha"},
        "report_sha256": {"$ref": "#/$defs/sha"},
        "receipt_sha256": {"$ref": "#/$defs/sha"},
        "source_bundle_sha256": {"$ref": "#/$defs/sha"},
        "semantic_plan_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "semantic_delta_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "runtime_proof": {
      "type": "object",
      "required": ["requested_model", "resolved_model", "provider", "resolution_mode", "attempt_id", "evidence_sha256"],
      "additionalProperties": false,
      "properties": {
        "requested_model": {"$ref": "#/$defs/nonEmpty"},
        "resolved_model": {"$ref": "#/$defs/nonEmpty"},
        "provider": {"$ref": "#/$defs/nonEmpty"},
        "resolution_mode": {"enum": ["native_per_agent", "isolated_cli", "inherited_current"]},
        "attempt_id": {"$ref": "#/$defs/nonEmpty"},
        "evidence_sha256": {"$ref": "#/$defs/sha"}
      }
    },
    "verdict": {"enum": ["approve", "reject", "needs_human"]},
    "reviewed_at": {"type": "string", "format": "date-time"},
    "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}}
  },
  "$defs": {
    "nonEmpty": {"type": "string", "minLength": 1},
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "identity": {
      "type": "object",
      "required": ["page_id", "cell_id"],
      "additionalProperties": false,
      "properties": {"page_id": {"$ref": "#/$defs/nonEmpty"}, "cell_id": {"$ref": "#/$defs/nonEmpty"}}
    },
    "evidence": {
      "type": "object",
      "required": ["kind", "path", "sha256", "pointer", "message"],
      "additionalProperties": false,
      "properties": {
        "kind": {"enum": ["artifact", "validation_report", "validation_receipt", "semantic_plan", "semantic_delta", "source_bundle", "comparison", "runtime_proof"]},
        "path": {"type": ["string", "null"], "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
        "sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "pointer": {"type": ["string", "null"]},
        "message": {"$ref": "#/$defs/nonEmpty"}
      }
    },
    "remediation": {
      "type": "object",
      "required": ["class", "action"],
      "additionalProperties": false,
      "properties": {"class": {"enum": ["repair", "regenerate", "clarify", "manual", "none"]}, "action": {"$ref": "#/$defs/nonEmpty"}}
    },
    "finding": {
      "type": "object",
      "required": ["finding_id", "category", "severity", "summary", "elements", "evidence", "remediation"],
      "additionalProperties": false,
      "properties": {
        "finding_id": {"$ref": "#/$defs/nonEmpty"},
        "category": {"enum": ["semantic", "layout", "routing", "validation", "source", "integrity"]},
        "severity": {"enum": ["info", "warning", "error"]},
        "summary": {"$ref": "#/$defs/nonEmpty"},
        "elements": {"type": "array", "items": {"$ref": "#/$defs/identity"}},
        "evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence"}},
        "remediation": {"$ref": "#/$defs/remediation"}
      }
    }
  }
}
