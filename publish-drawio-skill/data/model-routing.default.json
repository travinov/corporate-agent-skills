{
  "schema_version": 1,
  "policy_id": "diagram-supervisor-default-v1",
  "global_interactive_model": "preserve",
  "roles": {
    "supervisor": {
      "requested_model": "GigaChat-3-Ultra",
      "provider": "gigachat",
      "activation": "permanent",
      "prompt": "agents/diagram-supervisor.md",
      "mutation_policy": "orchestration_only",
      "fallback_order": ["isolated_cli", "native_per_agent", "inherited_current"],
      "runtime_fallbacks": [
        {
          "model": "vllm/DeepSeek-V4-Flash-262k",
          "provider": "vllm",
          "on_failure": ["turn_limit"],
          "max_attempts": 1
        }
      ]
    },
    "reviewer": {
      "requested_model": "vllm/DeepSeek-V4-Flash-262k",
      "provider": "vllm",
      "activation": "permanent",
      "prompt": "agents/diagram-reviewer.md",
      "mutation_policy": "read_only",
      "fallback_order": ["isolated_cli", "native_per_agent", "inherited_current"]
    },
    "repair": {
      "requested_model": "vllm/MiniMax-M3-113k",
      "provider": "vllm",
      "activation": "on_demand",
      "prompt": "agents/diagram-repair.md",
      "mutation_policy": "patch_proposal_only",
      "fallback_order": ["isolated_cli", "native_per_agent", "inherited_current"],
      "runtime_fallbacks": [
        {
          "model": "vllm/Qwen3.6-35B-262k",
          "provider": "vllm",
          "on_failure": ["timeout", "turn_limit", "model_unavailable", "empty_response"],
          "max_attempts": 1
        }
      ]
    },
    "semantic_analyst": {
      "requested_model": "vllm/Qwen3.6-35B-262k",
      "provider": "vllm",
      "activation": "on_demand",
      "prompt": "agents/diagram-semantic-analyst.md",
      "mutation_policy": "patch_proposal_only",
      "fallback_order": ["isolated_cli", "native_per_agent", "inherited_current"]
    }
  }
}
