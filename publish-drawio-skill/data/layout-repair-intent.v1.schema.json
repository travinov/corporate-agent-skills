{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents365.local/drawio-skill/schemas/layout-repair-intent.v1.schema.json",
  "title": "Layout repair intent v1",
  "type": "object",
  "required": ["schema_version", "role", "status", "run_id", "baseline_sha256", "result"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 1},
    "role": {"const": "repair"},
    "status": {"enum": ["ok", "needs_human", "failed"]},
    "run_id": {"$ref": "#/$defs/id"},
    "baseline_sha256": {"$ref": "#/$defs/sha"},
    "result": {"oneOf": [{"$ref": "#/$defs/scoped_result"}, {"$ref": "#/$defs/legacy_result"}]}
  },
  "$defs": {
    "id": {"type": "string", "minLength": 1},
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "action": {"enum": ["edge_reroute", "adjacent_nodes", "one_layer", "connected_component", "finish_best_effort"]},
    "legacy_action": {"enum": ["reroute_edges", "move_adjacent_nodes", "expand_layer", "expand_component", "finish_best_effort"]},
    "ids": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
    "scoped_result": {
      "type": "object",
      "required": ["action", "page_id", "target_edges", "movable_nodes", "locked_nodes", "reason"],
      "additionalProperties": false,
      "properties": {
        "action": {"$ref": "#/$defs/action"}, "page_id": {"$ref": "#/$defs/id"},
        "target_edges": {"$ref": "#/$defs/ids"}, "movable_nodes": {"$ref": "#/$defs/ids"},
        "locked_nodes": {"$ref": "#/$defs/ids"}, "reason": {"$ref": "#/$defs/id"}
      }
    },
    "legacy_result": {
      "type": "object",
      "required": ["action", "page_id", "node_ids", "edge_ids", "reason"],
      "additionalProperties": false,
      "properties": {
        "action": {"$ref": "#/$defs/legacy_action"}, "page_id": {"$ref": "#/$defs/id"},
        "node_ids": {"$ref": "#/$defs/ids"}, "edge_ids": {"$ref": "#/$defs/ids"},
        "reason": {"$ref": "#/$defs/id"}
      }
    }
  }
}
