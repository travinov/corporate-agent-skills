{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents365.local/drawio-skill/schemas/run-state.v2.schema.json",
  "title": "Diagram lifecycle state v2",
  "type": "object",
  "required": ["schema_version", "run_id", "status", "iteration", "updated_at", "transaction_id", "source_bundle_sha256", "previous_snapshot_sha256"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 2},
    "run_id": {"$ref": "#/$defs/nonEmpty"},
    "status": {"enum": ["initialized", "analyzing", "analyzed", "awaiting_decision", "patching", "validating", "accepted_candidate", "retrying", "plateau", "awaiting_feedback", "final_review", "reviewing", "publication_pending", "publication_conflict", "completed", "approved_with_findings", "manual_handoff", "stopped", "failed"]},
    "iteration": {"type": "integer", "minimum": 0},
    "updated_at": {"type": "string", "format": "date-time"},
    "transaction_id": {"$ref": "#/$defs/nonEmpty"},
    "source_bundle_sha256": {"$ref": "#/$defs/sha"},
    "accepted_artifact": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/file"}]},
    "validation_report": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/file"}]},
    "validation_receipt": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/file"}]},
    "reviewer_verdict": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/file"}]},
    "checkpoint_id": {"type": ["string", "null"], "minLength": 1},
    "publication_transaction_id": {"type": ["string", "null"], "minLength": 1},
    "last_error": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["code", "message", "recoverable"],
          "additionalProperties": false,
          "properties": {
            "code": {"$ref": "#/$defs/nonEmpty"},
            "message": {"$ref": "#/$defs/nonEmpty"},
            "recoverable": {"type": "boolean"},
            "evidence_path": {"type": ["string", "null"], "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"}
          }
        }
      ]
    },
    "previous_snapshot_sha256": {"$ref": "#/$defs/nullableSha"}
  },
  "$defs": {
    "nonEmpty": {"type": "string", "minLength": 1},
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "nullableSha": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "relativePath": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "file": {
      "type": "object",
      "required": ["path", "sha256", "byte_length"],
      "additionalProperties": false,
      "properties": {
        "path": {"$ref": "#/$defs/relativePath"},
        "sha256": {"$ref": "#/$defs/sha"},
        "byte_length": {"type": "integer", "minimum": 0}
      }
    }
  }
}
