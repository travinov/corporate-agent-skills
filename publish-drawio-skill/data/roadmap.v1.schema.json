{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents365.local/drawio-skill/schemas/roadmap.v1.schema.json",
  "title": "Roadmap v1",
  "type": "object",
  "required": ["schema_version", "title", "milestones"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 1},
    "title": {"type": "string", "minLength": 1},
    "time_scale": {"type": "string", "enum": ["week", "month", "quarter", "date", "order"], "default": "month"},
    "lane_dimension": {"type": "string", "minLength": 1},
    "shift_threshold_days": {"type": "integer", "minimum": 0},
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "lanes": {"type": "array", "items": {"$ref": "#/$defs/lane"}},
    "outcomes": {"type": "array", "items": {"$ref": "#/$defs/outcome"}},
    "tasks": {"type": "array"},
    "milestones": {"type": "array", "minItems": 1},
    "dependencies": {"type": "array", "items": {"$ref": "#/$defs/dependency"}},
    "baseline": {"type": "object"}
  },
  "allOf": [
    {
      "if": {"properties": {"time_scale": {"const": "order"}}, "required": ["time_scale"]},
      "then": {
        "properties": {
          "tasks": {"type": "array", "items": {"$ref": "#/$defs/orderTask"}},
          "milestones": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/orderMilestone"}},
          "baseline": {"$ref": "#/$defs/orderBaseline"}
        }
      },
      "else": {
        "properties": {
          "tasks": {"type": "array", "items": {"$ref": "#/$defs/calendarTask"}},
          "milestones": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/calendarMilestone"}},
          "baseline": {"$ref": "#/$defs/calendarBaseline"}
        }
      }
    }
  ],
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"},
    "date": {"type": "string", "format": "date"},
    "status": {"type": "string", "enum": ["planned", "in_progress", "on_track", "at_risk", "blocked", "done", "cancelled"]},
    "lane": {
      "type": "object", "required": ["id", "title"], "additionalProperties": false,
      "properties": {"id": {"$ref": "#/$defs/id"}, "title": {"type": "string", "minLength": 1}, "description": {"type": "string"}}
    },
    "outcome": {
      "type": "object", "required": ["id", "title"], "additionalProperties": false,
      "properties": {"id": {"$ref": "#/$defs/id"}, "title": {"type": "string", "minLength": 1}, "description": {"type": "string"}, "metric": {"type": "string"}}
    },
    "taskFields": {
      "type": "object",
      "properties": {
        "id": {"$ref": "#/$defs/id"}, "title": {"type": "string", "minLength": 1}, "lane": {"$ref": "#/$defs/id"},
        "status": {"$ref": "#/$defs/status"}, "risk": {"type": "string"}, "owner": {"type": "string"},
        "milestones": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "outcomes": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "notes": {"type": "string"}
      }
    },
    "calendarTask": {
      "type": "object", "required": ["id", "title", "start", "end"], "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/id"}, "title": {"type": "string", "minLength": 1}, "lane": {"$ref": "#/$defs/id"},
        "start": {"$ref": "#/$defs/date"}, "end": {"$ref": "#/$defs/date"}, "status": {"$ref": "#/$defs/status"},
        "risk": {"type": "string"}, "owner": {"type": "string"}, "milestones": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "outcomes": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "notes": {"type": "string"}
      }
    },
    "orderTask": {
      "type": "object", "required": ["id", "title", "start_order", "end_order"], "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/id"}, "title": {"type": "string", "minLength": 1}, "lane": {"$ref": "#/$defs/id"},
        "start_order": {"type": "integer"}, "end_order": {"type": "integer"}, "status": {"$ref": "#/$defs/status"},
        "risk": {"type": "string"}, "owner": {"type": "string"}, "milestones": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "outcomes": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "notes": {"type": "string"}
      }
    },
    "calendarMilestone": {
      "type": "object", "required": ["id", "title", "date"], "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/id"}, "title": {"type": "string", "minLength": 1}, "lane": {"$ref": "#/$defs/id"},
        "date": {"$ref": "#/$defs/date"}, "status": {"$ref": "#/$defs/status"}, "risk": {"type": "string"}, "owner": {"type": "string"},
        "outcomes": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "notes": {"type": "string"}
      }
    },
    "orderMilestone": {
      "type": "object", "required": ["id", "title", "order"], "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/id"}, "title": {"type": "string", "minLength": 1}, "lane": {"$ref": "#/$defs/id"},
        "order": {"type": "integer"}, "status": {"$ref": "#/$defs/status"}, "risk": {"type": "string"}, "owner": {"type": "string"},
        "outcomes": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "notes": {"type": "string"}
      }
    },
    "dependency": {
      "type": "object", "required": ["id", "from", "to"], "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/id"}, "from": {"$ref": "#/$defs/id"}, "to": {"$ref": "#/$defs/id"},
        "type": {"type": "string", "enum": ["blocks", "depends_on", "influences", "relates_to"]},
        "impact": {"type": "string", "enum": ["low", "medium", "high"]}, "rationale": {"type": "string"}
      }
    },
    "calendarBaseline": {
      "type": "object", "additionalProperties": false,
      "properties": {"version": {"type": "string"}, "tasks": {"type": "array", "items": {"$ref": "#/$defs/calendarTask"}}, "milestones": {"type": "array", "items": {"$ref": "#/$defs/calendarMilestone"}}, "dependencies": {"type": "array", "items": {"$ref": "#/$defs/dependency"}}, "outcomes": {"type": "array", "items": {"$ref": "#/$defs/outcome"}}}
    },
    "orderBaseline": {
      "type": "object", "additionalProperties": false,
      "properties": {"version": {"type": "string"}, "tasks": {"type": "array", "items": {"$ref": "#/$defs/orderTask"}}, "milestones": {"type": "array", "items": {"$ref": "#/$defs/orderMilestone"}}, "dependencies": {"type": "array", "items": {"$ref": "#/$defs/dependency"}}, "outcomes": {"type": "array", "items": {"$ref": "#/$defs/outcome"}}}
    }
  }
}
