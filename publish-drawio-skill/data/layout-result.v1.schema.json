{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://agents365.local/drawio-skill/schemas/layout-result.v1.schema.json", "title": "Deterministic layout result v1", "type": "object",
  "required": ["schema_version", "result_id", "request_sha256", "backend", "pages", "metrics"], "additionalProperties": false,
  "properties": {"schema_version": {"const": 1}, "result_id": {"$ref": "#/$defs/id"}, "request_sha256": {"$ref": "#/$defs/sha"}, "backend": {"$ref": "#/$defs/id"}, "pages": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/page"}}, "metrics": {"$ref": "#/$defs/metrics"}},
  "$defs": {
    "id": {"type": "string", "minLength": 1}, "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "number": {"type": "number"},
    "point": {"type": "object", "required": ["x", "y"], "additionalProperties": false, "properties": {"x": {"$ref": "#/$defs/number"}, "y": {"$ref": "#/$defs/number"}}},
    "rect": {"type": "object", "required": ["x", "y", "width", "height"], "additionalProperties": false, "properties": {"x": {"$ref": "#/$defs/number"}, "y": {"$ref": "#/$defs/number"}, "width": {"type": "number", "exclusiveMinimum": 0}, "height": {"type": "number", "exclusiveMinimum": 0}}},
    "pin": {"type": "number", "minimum": 0.1, "maximum": 0.9},
    "reservation": {"type": "object", "required": ["edge_id", "start", "end"], "additionalProperties": false, "properties": {"edge_id": {"$ref": "#/$defs/id"}, "start": {"$ref": "#/$defs/point"}, "end": {"$ref": "#/$defs/point"}}},
    "node": {"type": "object", "required": ["node_id", "x", "y", "width", "height", "locked"], "additionalProperties": false, "properties": {"node_id": {"$ref": "#/$defs/id"}, "x": {"$ref": "#/$defs/number"}, "y": {"$ref": "#/$defs/number"}, "width": {"type": "number", "exclusiveMinimum": 0}, "height": {"type": "number", "exclusiveMinimum": 0}, "locked": {"type": "boolean"}}},
    "edge": {"type": "object", "required": ["edge_id", "source", "target", "edge_class", "source_port", "target_port", "source_pin", "target_pin", "waypoints"], "additionalProperties": false, "properties": {"edge_id": {"$ref": "#/$defs/id"}, "source": {"$ref": "#/$defs/id"}, "target": {"$ref": "#/$defs/id"}, "edge_class": {"enum": ["main", "branch", "feedback", "self_loop"]}, "route_group": {"$ref": "#/$defs/id"}, "source_port": {"enum": ["north", "east", "south", "west"]}, "target_port": {"enum": ["north", "east", "south", "west"]}, "source_pin": {"$ref": "#/$defs/pin"}, "target_pin": {"$ref": "#/$defs/pin"}, "waypoints": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/point"}}, "label_bounds": {"$ref": "#/$defs/rect"}}},
    "page": {"type": "object", "required": ["page_id", "name", "nodes", "edges"], "additionalProperties": false, "properties": {"page_id": {"$ref": "#/$defs/id"}, "name": {"type": "string"}, "nodes": {"type": "array", "items": {"$ref": "#/$defs/node"}}, "edges": {"type": "array", "items": {"$ref": "#/$defs/edge"}}, "channel_reservations": {"type": "array", "items": {"$ref": "#/$defs/reservation"}}}},
    "metrics": {"type": "object", "required": ["crossings", "overlaps", "route_length", "bend_count", "shared_route_length", "label_collisions"], "additionalProperties": false, "properties": {"crossings": {"type": "integer", "minimum": 0}, "overlaps": {"type": "integer", "minimum": 0}, "route_length": {"type": "number", "minimum": 0}, "bend_count": {"type": "integer", "minimum": 0}, "shared_route_length": {"type": "number", "minimum": 0}, "label_collisions": {"type": "integer", "minimum": 0}}}
  }
}
